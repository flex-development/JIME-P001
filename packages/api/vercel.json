{
  "functions": {
    "api/*.ts": {
      "memory": 3008
    },
    "api/assets/images/[filename].ts": {
      "includeFiles": "_files/**"
    },
    "lib/controllers/AssetsController.ts": {
      "includeFiles": "../../api/assets/images/_files/**"
    },
    "lib/services/AssetService.ts": {
      "includeFiles": "../../api/assets/images/_files/**"
    }
  },
  "github": {
    "autoAlias": true,
    "enabled": true,
    "silent": false
  },
  "headers": [
    {
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, must-revalidate"
        }
      ],
      "source": "/api/assets/(.*)"
    },
    {
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate"
        }
      ],
      "source": "/(.*)"
    }
  ],
  "redirects": [
    {
      "destination": "https://github.com/flex-development/JIME-P001",
      "permanent": true,
      "source": "/repo"
    }
  ],
  "rewrites": [
    {
      "destination": "/api",
      "source": "/"
    },
    {
      "destination": "/api/:path*",
      "source": "/:path*"
    }
  ]
}
